ACTION_FOR_EACH lv1spell IN 104 105 108 109 110 111 112 113 114 BEGIN
COPY_EXISTING ~C0WL%lv1spell%.spl~ ~override/C0W^%lv1spell%.spl~
LPF ALTER_EFFECT INT_VAR match_opcode = 206 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W^%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR match_opcode = 321 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W^%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR match_opcode = 318 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W^%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR match_opcode = 324 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W^%lv1spell%~ END
COPY_EXISTING ~C0WL%lv1spell%.spl~ ~override/C0W_%lv1spell%.spl~
LPF ALTER_EFFECT INT_VAR match_opcode = 206 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W_%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR match_opcode = 321 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W_%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR match_opcode = 318 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W_%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR match_opcode = 324 silent = 1 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W_%lv1spell%~ END
LPF ALTER_EFFECT INT_VAR silent = 1 match_opcode = 321 STR_VAR match_resource = EVAL ~C0WL%lv1spell%~ resource = EVAL ~C0W_%lv1spell%~ END
SAY NAME1 #-1
COPY_EXISTING ~C0WL%lv1spell%.spl~ ~override~
WRITE_SHORT 0x1C 3 
LPF ALTER_SPELL_HEADER INT_VAR location = 2 END
LPF DELETE_SPELL_EFFECT INT_VAR opcode_to_delete = %-1% END
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 171 target = 1 timing = 1 STR_VAR resource = EVAL ~C0WL%lv1spell%~ END
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 172 target = 1 timing = 1 STR_VAR resource = EVAL ~C0WL%lv1spell%~ END
READ_BYTE 0x7e target
	PATCH_IF (target = 1) OR (target = 5) OR (target = 7) BEGIN
		LPF ALTER_SPELL_HEADER INT_VAR projectile = 0 END
		LPF ADD_SPELL_EFFECT INT_VAR opcode = 146 target = 2 parameter2 = 1 timing = 1 STR_VAR resource = EVAL ~C0W_%lv1spell%~ END
		END
	PATCH_IF (target = 4) BEGIN
		LPF ADD_SPELL_EFFECT INT_VAR opcode = 148 target = 1 parameter2 = 1 timing = 1 STR_VAR resource = EVAL ~C0W_%lv1spell%~ END
		END

COPY_EXISTING ~C0WL%lv1spell%z.spl~ ~override~
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 1 timing = 1 STR_VAR resource = EVAL ~C0W^%lv1spell%~ END

END

