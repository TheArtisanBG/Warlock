COPY_EXISTING ~C0WL%blasts_level%z.spl~ ~override~
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%~ END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%B~ END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%C~ END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%D~ END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%E~ END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%B~ END
LPF ADD_SPELL_EFFECT INT_VAR opcode = 172 target = 2 timing = 1 STR_VAR resource = EVAL ~C0W^%blasts_level%I~ END

