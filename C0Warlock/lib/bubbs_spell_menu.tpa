  REPLACE_TEXTUALLY ~c0wlxxxa~ ~c0wl%blast%a~
  REPLACE_TEXTUALLY ~c0wlxxxb~ ~c0wl%blast%b~
  REPLACE_TEXTUALLY ~c0wlxxxc~ ~c0wl%blast%c~
  REPLACE_TEXTUALLY ~c0wlxxxi~ ~c0wl%blast%i~
  REPLACE_TEXTUALLY ~c0wlxxxd~ ~c0wl%blast%d~
  REPLACE_TEXTUALLY ~c0wlxxxe~ ~c0wl%blast%e~
  REPLACE_TEXTUALLY ~c0wlxxxf~ ~c0wl%blast%f~

COPY ~%MOD_FOLDER%/spells/bubb/C0WL100.spl~ ~override/C0WL%blast%A.spl~
LPF ALTER_SPELL_HEADER STR_VAR icon = EVAL ~C0WL%blast%B~ END
LPF ALTER_EFFECT STR_VAR match_resource = C0WL106B resource = EVAL ~C0WL%blast%B~ END
LPF ALTER_EFFECT STR_VAR match_resource = C0WL106C resource = EVAL ~C0WL%blast%C~ END
