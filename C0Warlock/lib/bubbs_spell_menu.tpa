COPY_EXISTING ~C0WL%blasts_level%.spl~ ~override~
WRITE_SHORT 0x1C 3 
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 171 target = 1 timing = 1 STR_VAR resource = EVAL ~C0WL%blasts_level%~ END
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 172 target = 1 timing = 1 STR_VAR resource = EVAL ~C0WL%blasts_level%~ END
COPY_EXISTING ~C0WL%blasts_level%b.spl~ ~override~
WRITE_BYTE 0x1C 3
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 171 target = 1 timing = 1 STR_VAR resource = EVAL ~%SOURCE_RES%~ END
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 172 target = 1 timing = 1 STR_VAR resource = EVAL ~%SOURCE_RES%~ END
COPY_EXISTING ~C0WL%blasts_level%c.spl~ ~override~
WRITE_BYTE 0x1C 3
LPF ADD_SPELL_CFEFFECT INT_VAR opcode = 171 target = 1 timing = 1 STR_VAR resource = EVAL ~%SOURCE_RES%~ END
